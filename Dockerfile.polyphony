# polyphony-dev Container (*FR:Brunel*)
#
# Extends ai-teams-claude:latest (ubuntu 24.04, nodejs 18, npm, git, gh, gosu, claude)
# with pnpm, wrangler, Playwright/Chromium, SSH server, tmux, and Europe/Tallinn timezone.
#
# Named volumes (no host bind mounts):
#   polyphony-claude-home  → /home/ai-teams/.claude    (Claude state + auto-memory)
#   polyphony-repo         → /home/ai-teams/workspace  (git repo, pnpm deps installed here)
#
# Ports:
#   2223  — SSH (PO access, auto-tmux on login)
#   5173  — vault dev server (vite)
#   5174  — registry dev server (vite)
#
# Build:
#   docker compose -f docker-compose.polyphony.yml build
#
# Connect:
#   ssh -i ~/.ssh/id_ed25519_polyphony -p 2223 ai-teams@<host>

FROM ai-teams-claude:latest

# ── Fix inherited apt sources ──────────────────────────────────────────────────
# Base image adds GitHub CLI apt repo with a key that may go stale.
# gh is already installed — remove the apt source, it's not needed.
RUN rm -f /etc/apt/sources.list.d/github-cli.list \
    && rm -f /usr/share/keyrings/githubcli-archive-keyring.gpg

# ── Node.js 22 LTS ────────────────────────────────────────────────────────────
# Base image has Node.js 18 from Ubuntu apt — too old for Claude Code and
# modern pnpm. Download binary directly.
#
# WARP note: build uses network: host (see docker-compose.polyphony.yml), so
# apt-get update reaches Ubuntu repos through the WARP tunnel. curl --insecure
# is still needed for the nodejs.org download because WARP does TLS
# interception and the container doesn't yet trust the WARP CA at build time.
# This is a BUILD-TIME-ONLY workaround; the binary is identified by versioned filename.
RUN apt-get update && apt-get install -y --no-install-recommends curl \
    && curl --insecure -fsSL https://nodejs.org/dist/v22.14.0/node-v22.14.0-linux-x64.tar.gz \
       -o /tmp/node.tar.gz \
    && tar -xzf /tmp/node.tar.gz -C /usr/local --strip-components=1 \
    && rm /tmp/node.tar.gz \
    && node --version \
    && npm install -g npm@latest 2>&1 | tail -1 \
    && rm -rf /var/lib/apt/lists/*

# ── Timezone + SSH server + tmux + Playwright system deps ────────────────────
# tzdata: Europe/Tallinn system timezone
# openssh-server: PO SSH access on port 2223
# tmux: auto-tmux on SSH login (session persistence)
# locales: en_US.UTF-8 for tmux -u Unicode rendering
# Playwright Chromium system deps: minimal headless Chromium set for Ubuntu 24.04
#   (source: playwright install-deps chromium ubuntu-24.04 list)
# DEBIAN_FRONTEND=noninteractive prevents tzdata interactive prompt.
ENV DEBIAN_FRONTEND=noninteractive
RUN apt-get update && apt-get install -y --no-install-recommends \
        tzdata \
        openssh-server \
        tmux \
        locales \
        libnss3 \
        libatk1.0-0t64 \
        libatk-bridge2.0-0t64 \
        libcups2t64 \
        libdrm2 \
        libxkbcommon0 \
        libxcomposite1 \
        libxdamage1 \
        libxfixes3 \
        libxrandr2 \
        libgbm1 \
        libasound2t64 \
    && rm -rf /var/lib/apt/lists/* \
    && sed -i 's/# en_US.UTF-8/en_US.UTF-8/' /etc/locale.gen && locale-gen \
    && ln -snf /usr/share/zoneinfo/Europe/Tallinn /etc/localtime \
    && echo "Europe/Tallinn" > /etc/timezone \
    && dpkg-reconfigure -f noninteractive tzdata \
    && mkdir -p /run/sshd \
    && ssh-keygen -A \
    && sed -i 's/^#\?PermitRootLogin.*/PermitRootLogin no/' /etc/ssh/sshd_config \
    && sed -i 's/^#\?PasswordAuthentication.*/PasswordAuthentication no/' /etc/ssh/sshd_config \
    && sed -i 's/^#\?ChallengeResponseAuthentication.*/ChallengeResponseAuthentication no/' /etc/ssh/sshd_config \
    && sed -i 's/^#\?UsePAM.*/UsePAM no/' /etc/ssh/sshd_config \
    && sed -i 's/^#\?Port .*/Port 2223/' /etc/ssh/sshd_config \
    && echo 'Port 2223' >> /etc/ssh/sshd_config
ENV DEBIAN_FRONTEND=

# ── ai-teams SSH access ────────────────────────────────────────────────────────
# Unlock account for SSH pubkey auth.
# UsePAM=no rejects locked accounts (! in /etc/shadow) even for pubkey auth.
# '*' = no password (pubkey works). '!' = locked (all auth rejected).
# Prepare .ssh dir; authorized_keys injected by entrypoint from SSH_PUBLIC_KEY* env vars.
RUN usermod -p '*' ai-teams \
    && mkdir -p /home/ai-teams/.ssh \
    && chmod 700 /home/ai-teams/.ssh \
    && chown 1000:1000 /home/ai-teams/.ssh

# ── pnpm ──────────────────────────────────────────────────────────────────────
# Install pnpm globally via npm. Version pinned to match packageManager field
# in polyphony/package.json (pnpm@9.15.0). Agents run pnpm from the workspace.
RUN npm install -g pnpm@9.15.0 2>&1 | tail -2

# ── Playwright Chromium browser ───────────────────────────────────────────────
# Install Chromium browser binary for Playwright E2E tests.
# --with-deps is redundant here (we installed deps above) but harmless.
# Browser downloads to whichever $HOME/.cache/ms-playwright/ is active.
# On this image, HOME=/home/ai-teams (set in base Dockerfile).
# Copy to a shared location so all users can access it.
RUN npx playwright install chromium 2>&1 | tail -5 \
    && mkdir -p /opt/playwright \
    && cp -r /home/ai-teams/.cache/ms-playwright /opt/playwright/cache \
    && chmod -R a+rX /opt/playwright

# ── Native Claude Code install ────────────────────────────────────────────────
# Install Claude Code natively (not npm-global) so auto-updates work without sudo.
# --insecure for WARP TLS interception at build time.
RUN gosu ai-teams bash -c 'curl --insecure -fsSL https://claude.ai/install.sh | bash' 2>&1 | tail -5

# ── Entrypoint ────────────────────────────────────────────────────────────────
COPY entrypoint-polyphony.sh /entrypoint-polyphony.sh
RUN chmod +x /entrypoint-polyphony.sh

WORKDIR /home/ai-teams/workspace

EXPOSE 2223 5173 5174

ENTRYPOINT ["/entrypoint-polyphony.sh"]
CMD ["bash"]
